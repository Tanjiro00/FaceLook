{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "next-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "next-devtools-mcp@latest"
      ]
    },
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--read-only"
      ]
    },
    "stripe": {
      "type": "http",
      "url": "https://mcp.stripe.com"
    },
    "vercel": {
      "command": "npx",
      "args": [
        "-y",
        "vercel-mcp@latest"
      ]
    }
  }
}
